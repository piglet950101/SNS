  "dependencies": {
    "drizzle-orm": "0.33.0",
    "postgres": "3.4.4"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
    "drizzle-kit": "0.24.2",
    "tsx": "4.19.1",
    "typescript": "5.4.5"
  }
