{
  "name": "postari",
  "version": "0.1.0",
  "private": true,
  "description": "Postari — SNS auto-posting SaaS for Japanese concept cafes",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @postari/db generate",
    "db:migrate": "pnpm --filter @postari/db migrate",
    "db:push": "pnpm --filter @postari/db push",
    "db:studio": "pnpm --filter @postari/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
    "eslint": "8.57.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "turbo": "2.1.3",
    "typescript": "5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["prettier --write", "eslint --fix"],
    "*.{json,md}": ["prettier --write"]
  }
}
