# =============================================================================
# Postari — Environment Variables (Phase 1)
# =============================================================================
# Copy this file to .env for local dev. Production values live in Render Secret
# Files / Env Vars only. NEVER commit real values to git.
# =============================================================================

# ---- Core -------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
DATABASE_URL=postgres://postari:postari@localhost:5432/postari
REDIS_URL=redis://localhost:6379

# ---- Auth (Clerk) -----------------------------------------------------------
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/post
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding/store

# ---- Cloudflare R2 (var names per client spec) ------------------------------
CLOUDFLARE_ACCOUNT_ID=xxx
CLOUDFLARE_R2_ACCESS_KEY_ID=xxx
CLOUDFLARE_R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=postari-images
R2_PUBLIC_URL=https://images.postari.jp
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# ---- Anthropic (Claude) -----------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- X (Twitter) ------------------------------------------------------------
X_OAUTH_CLIENT_ID=xxx
X_OAUTH_CLIENT_SECRET=xxx
X_OAUTH_CALLBACK_URL=http://localhost:3000/api/oauth/x/callback

# ---- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (create in dashboard, paste here)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STANDARD_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_ANNUAL=price_xxx
STRIPE_PRICE_STANDARD_ANNUAL=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_OVERAGE=price_xxx

# ---- Token lifecycle --------------------------------------------------------
TOKEN_REFRESH_CRON=0 0 * * *
TOKEN_EXPIRY_WARNING_DAYS=3

# ---- Encryption (32-byte base64; generate: openssl rand -base64 32) --------
TOKEN_ENCRYPTION_KEY=replace-me-with-32-byte-base64-random

# ---- Observability ----------------------------------------------------------
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_DSN_WORKER=

# ---- Email / Support --------------------------------------------------------
SUPPORT_EMAIL=support@postari.jp
FROM_EMAIL=noreply@postari.jp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---- Alerts (optional) ------------------------------------------------------
SLACK_WEBHOOK_URL=
