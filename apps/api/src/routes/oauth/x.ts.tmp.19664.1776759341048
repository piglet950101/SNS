import { Router } from 'express'
import { eq } from 'drizzle-orm'
import { stores } from '@postari/db'
import { db } from '../../lib/db'
import { env } from '../../env'
import { requireAuth } from '../../middleware/auth'
import { oauthRateLimit } from '../../middleware/rate-limit'
import { badRequest, forbidden, notFound } from '../../lib/errors'
import { encrypt } from '../../lib/encryption'
import { redis } from '../../lib/redis'
import { logger } from '../../lib/logger'
import {
  buildAuthorizeUrl,
  createPkceChallenge,
  exchangeCodeForTokens,
  fetchXUsername,
} from '../../lib/x-oauth'

export const xOAuthRouter = Router()

/**
 * OAuth PKCE sessions are stored in Redis keyed by the `state` parameter. We
 * do not use cookies because the Next.js callback (postari.jp) and the API
 * (api.postari.jp) live on different subdomains — Redis-backed lookups avoid
 * cookie-domain mismatch issues.
 *
 * We still require the user to be authenticated when initiating; the state
 * token itself is random + one-shot + 10-minute TTL.
 */

const SESSION_TTL_SEC = 10 * 60 // 10 minutes
const sessionKey = (state: string) => `oauth:x:${state}`

interface OAuthSession {
  userId: string
  storeId: string
  verifier: string
}

xOAuthRouter.get('/start', oauthRateLimit, requireAuth, async (req, res, next) => {
  try {
    const storeId = req.query.storeId
    if (typeof storeId !== 'string' || !/^[0-9a-f-]{36}$/.test(storeId)) {
      throw badRequest('storeId が必要です')
    }

    // Verify the requesting user owns the store
    const store = await db.query.stores.findFirst({
      where: eq(stores.id, storeId),
      columns: { id: true, userId: true },
    })
    if (!store) throw notFound('店舗が見つかりません')
    if (store.userId !== req.auth!.userId) throw forbidden()

    const challenge = createPkceChallenge()
    const authorizeUrl = buildAuthorizeUrl(challenge)

    const session: OAuthSession = {
      userId: req.auth!.userId,
      storeId,
      verifier: challenge.codeVerifier,
    }
    // Encrypt at-rest in Redis as defense-in-depth.
    await redis.set(
      sessionKey(challenge.state),
      encrypt(JSON.stringify(session)),
      'EX',
      SESSION_TTL_SEC,
    )

    res.json({ url: authorizeUrl })
  } catch (err) {
    next(err)
  }
})

/**
 * The Next.js web app hosts the user-facing callback at /api/oauth/x/callback.
 * It POSTs the code + state here, then redirects the user back to UX.
 */
xOAuthRouter.post('/callback', oauthRateLimit, requireAuth, async (req, res, next) => {
  try {
    const { code, state } = req.body as { code?: string; state?: string }
    if (!code || !state) throw badRequest('code と state が必要です')

    // Atomic: fetch + delete ensures the session is used exactly once.
    const stored = await redis.getdel(sessionKey(state))
    if (!stored) throw badRequest('セッションが切れました。もう一度お試しください。')

    let session: OAuthSession
    try {
      const { decrypt } = await import('../../lib/encryption')
      session = JSON.parse(decrypt(stored))
    } catch {
      throw badRequest('セッションの復号に失敗しました')
    }

    // The user who initiated the flow must match the user completing it.
    if (session.userId !== req.auth!.userId) throw forbidden()

    const store = await db.query.stores.findFirst({
      where: eq(stores.id, session.storeId),
      columns: { id: true, userId: true },
    })
    if (!store) throw notFound('店舗が見つかりません')
    if (store.userId !== req.auth!.userId) throw forbidden()

    const tokens = await exchangeCodeForTokens({
      code,
      codeVerifier: session.verifier,
    })

    const username = await fetchXUsername(tokens.access_token)

    const now = new Date()
    const expiresAt = new Date(now.getTime() + tokens.expires_in * 1000)

    await db
      .update(stores)
      .set({
        xAccessToken: encrypt(tokens.access_token),
        xRefreshToken: tokens.refresh_token ? encrypt(tokens.refresh_token) : null,
        xUsername: username,
        xConnectedAt: now,
        xTokenExpiresAt: expiresAt,
        tokenRefreshFailedAt: null,
        updatedAt: now,
      })
      .where(eq(stores.id, session.storeId))

    logger.info({ storeId: session.storeId, username }, 'X OAuth connected')
    res.json({ ok: true, username, storeId: session.storeId })
  } catch (err) {
    next(err)
  }
})

xOAuthRouter.delete('/disconnect', requireAuth, async (req, res, next) => {
  try {
    const storeId = req.query.storeId
    if (typeof storeId !== 'string') throw badRequest('storeId が必要です')

    const store = await db.query.stores.findFirst({
      where: eq(stores.id, storeId),
      columns: { id: true, userId: true },
    })
    if (!store) throw notFound()
    if (store.userId !== req.auth!.userId) throw forbidden()

    await db
      .update(stores)
      .set({
        xAccessToken: null,
        xRefreshToken: null,
        xUsername: null,
        xConnectedAt: null,
        xTokenExpiresAt: null,
        tokenRefreshFailedAt: null,
        updatedAt: new Date(),
      })
      .where(eq(stores.id, storeId))

    res.json({ ok: true })
  } catch (err) {
    next(err)
  }
})
